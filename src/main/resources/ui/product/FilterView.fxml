<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" prefWidth="350.0" prefHeight="300.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.product.FilterController"
      style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>
    <children>
        <Label text="Bộ Lọc Tìm Kiếm" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #007bff;"/>

        <Separator/>

        <VBox spacing="5.0">
            <Label text="Khoảng giá:"/>
            <Slider fx:id="priceSlider" showTickLabels="true" showTickMarks="true"/>
        </VBox>

        <CheckBox text="Sản phẩm đang đấu giá sôi nổi"/>
        <CheckBox text="Chỉ xem sản phẩm của Admin"/>

        <HBox spacing="15.0" alignment="CENTER_RIGHT">
            <Button text="Hủy" onAction="#handleClose"
                    style="-fx-background-color: #f8d7da; -fx-text-fill: #721c24; -fx-cursor: hand;"/>
            <Button text="Áp dụng" onAction="#handleApply"
                    style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </children>
</VBox>

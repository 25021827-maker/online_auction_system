<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="0.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AuctionController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Label text="BID-AUCTION" textFill="#1976d2">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="400.0" promptText="Tìm kiếm sản phẩm đấu giá..." style="-fx-background-radius: 20;" />
                        <Button mnemonicParsing="false" onAction="#openFilter" prefHeight="35.0" prefWidth="80.0" style="-fx-background-radius: 20; -fx-background-color: #f0f0f0; -fx-cursor: hand;" text="⚙ Lọc">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Tiêu đề">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <FlowPane fx:id="productsContainer" hgap="20.0" vgap="20.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
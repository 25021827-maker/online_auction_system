<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.user.AdminController">
    <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;" prefWidth="250.0">
        <Label text="HỆ THỐNG ADMIN" textFill="WHITE">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <Separator/>
        <Button maxWidth="Infinity" text="8. Dashboard Thống kê" onAction="#switchDashboard"/>
        <Button maxWidth="Infinity" text="9. Quản lý Người dùng" onAction="#switchUsers"/>
        <Button maxWidth="Infinity" text="10. Quản lý Sản phẩm" onAction="#switchProducts"/>
        <Button maxWidth="Infinity" text="11. Quản lý Phiên ĐG" onAction="#switchAuctions"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f4f4f4; -fx-padding: 20;">
        <Label fx:id="lblTitle" text="Bảng điều khiển quản trị">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>
        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-padding: 15;">
            <TableView fx:id="tableCommon" visible="false" />
            <Label fx:id="lblWelcome" text="Chọn một chức năng bên trái để quản lý" />
        </StackPane>
    </VBox>
</HBox>

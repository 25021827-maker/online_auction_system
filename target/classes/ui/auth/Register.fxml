<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0"
      style="-fx-background-color: #f0f2f5;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.auth.RegisterController">

    <Label text="ĐĂNG KÝ">
        <font>
            <Font name="System Bold" size="28.0"/>
        </font>
    </Label>

    <VBox maxWidth="300" spacing="10">
        <TextField fx:id="txtUser" prefHeight="35" promptText="Tên đăng nhập"/>
        <PasswordField fx:id="txtPass" prefHeight="35" promptText="Mật khẩu"/>
        <PasswordField fx:id="txtConfirm" prefHeight="35" promptText="Nhập lại mật khẩu"/>

        <Button text="Đăng ký" onAction="#handleRegister" maxWidth="Infinity"/>
        <Button text="Quay lại" onAction="#goToLogin" maxWidth="Infinity"/>

        <Label fx:id="lblMessage"/>
    </VBox>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.auth.LoginController">
    <Label text="HỆ THỐNG ĐẤU GIÁ">
        <font><Font name="System Bold" size="28.0" /></font>
    </Label>

    <VBox maxWidth="300" spacing="10">
        <TextField fx:id="txtUser" prefHeight="35" promptText="Tên đăng nhập" />
        <PasswordField fx:id="txtPass" prefHeight="35" promptText="Mật khẩu" />
        <Button onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #1877f2; ..." text="Đăng nhập" defaultButton = "true"/>
        <HBox alignment="CENTER" spacing="5">
            <Label text="Chưa có tài khoản?" />
            <Hyperlink onAction="#handleRegister" text="Đăng ký ngay" />
        </HBox>
    </VBox>
</VBox>
